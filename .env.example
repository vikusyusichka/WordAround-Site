# Firebase Web SDK config — copied from Firebase console → Project settings → Web app
# These are NOT secrets. They are safe to commit or expose to the browser.
# Real security is enforced by Firestore/Storage rules on the server side.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloudflare Worker (AI provider router + Whisper + Azure Speech tokens)
VITE_AI_WORKER_URL=
