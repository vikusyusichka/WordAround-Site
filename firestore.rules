rules_version = '2';

/* WordAround Firestore rules.
 *
 * This file is a VERBATIM copy of the rules that are live on the shared
 * Firebase project (wordaround-97f86), captured 2026-07-22. It is kept here so
 * the rules are reviewable and restorable — previously they existed only inside
 * the Firebase Console, with no history and no undo.
 *
 * ── Review, 2026-07-22 ──────────────────────────────────────────────────────
 * Audited against every Firestore path in BOTH codebases (web
 * `src/lib/firestore.ts`, iOS `Core/Services/Firebase/*.swift`). The live rules
 * are correct and complete; no change was needed. Every path either app uses is
 * covered and owner-scoped:
 *
 *   users/{uid}/folders/{id}                                   ✔ covered
 *   users/{uid}/flashcardSets/{id}                             ✔ covered
 *   users/{uid}/readingItems/{id}                              ✔ covered
 *   users/{uid}/grammarReviewItems/{id}                        ✔ covered
 *   users/{uid}/grammarNoteTopics/{topicId}                    ✔ covered
 *   users/{uid}/grammarNoteTopics/{topicId}/notes/{noteId}     ✔ via the
 *   …/notes/{noteId}/quizzes/{quizId}                            `{document=**}`
 *                                                                rule on topics
 *
 * The Cloud Function (iOS repo, functions/index.js) is a stateless Gemini proxy
 * and never touches Firestore, so nothing here affects it.
 *
 * `users/{uid}/grammarNotes/**` and `users/{uid}/grammarNoteQuizzes/**` are not
 * written by the current web or iOS code — they look like an earlier, flat
 * layout. They are owner-scoped and harmless, so they are left in place rather
 * than removed: deleting rules for data that might still exist would make it
 * unreachable.
 *
 * ── A rejected "improvement" ────────────────────────────────────────────────
 * Collapsing all of this into a single `match /users/{uid}/{document=**}` was
 * considered and REJECTED. It reads tidier, but it would also have denied the
 * `users/{uid}` profile document, which these rules allow. No code was found
 * that writes it — but "not found" is not "does not exist", and this project
 * backs a shipped iOS app with real users. Not worth the risk for zero security
 * gain.
 *
 * Note that enumerating collections means any NEW collection is denied until it
 * is added here. That fails closed (safe) but will look like a mysterious
 * permission error — if a future feature adds a collection under users/{uid},
 * add a matching rule here and publish it.
 *
 * To change these: see docs/SECURITY-RULES.md.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile document
    match /users/{userId} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    // Flashcard sets
    match /users/{userId}/flashcardSets/{setId} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    match /users/{userId}/flashcardSets/{setId}/{document=**} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    // Folders
    match /users/{userId}/folders/{folderId} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    match /users/{userId}/folders/{folderId}/{document=**} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    // Grammar Topics
    match /users/{userId}/grammarNoteTopics/{topicId} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    match /users/{userId}/grammarNoteTopics/{topicId}/{document=**} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    // Grammar Notes
    match /users/{userId}/grammarNotes/{noteId} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    match /users/{userId}/grammarNotes/{noteId}/{document=**} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    // Grammar Quizzes
    match /users/{userId}/grammarNoteQuizzes/{quizId} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    match /users/{userId}/grammarNoteQuizzes/{quizId}/{document=**} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    // Review Items
    match /users/{userId}/grammarReviewItems/{reviewItemId} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    match /users/{userId}/grammarReviewItems/{reviewItemId}/{document=**} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    // Reading Items
    match /users/{userId}/readingItems/{itemId} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }

    match /users/{userId}/readingItems/{itemId}/{document=**} {
      allow read, write: if request.auth != null
                           && request.auth.uid == userId;
    }
  }
}
